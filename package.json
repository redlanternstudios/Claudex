{
  "name": "@redlantern/claudex-bridge",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bridge": "node scripts/bridge.mjs",
    "bridge:status": "node scripts/bridge.mjs status",
    "bridge:validate": "node scripts/bridge.mjs validate",
    "bridge:doctor": "node scripts/bridge.mjs doctor",
    "bridge:align": "node scripts/alignment.mjs check",
    "bridge:sync": "node scripts/alignment.mjs sync",
    "bridge:publish": "node scripts/alignment.mjs publish",
    "bridge:watch": "node scripts/alignment.mjs sync --apply",
    "bridge:install": "node scripts/install-scheduler.mjs",
    "heartbeat": "node scripts/heartbeat.mjs",
    "heartbeat:install": "node scripts/install-heartbeat-scheduler.mjs",
    "backlog:status": "node scripts/backlog.mjs status",
    "backlog:validate": "node scripts/backlog.mjs validate",
    "backlog:json": "node scripts/backlog.mjs json",
    "content:route": "node scripts/content-route.mjs route",
    "content:validate": "node scripts/content-route.mjs validate",
    "obsidian:install": "node scripts/install-obsidian-scheduler.mjs",
    "rory:activity": "node scripts/rory-activity.mjs",
    "rory:status": "node scripts/rory-activity-status.mjs",
    "docs:redlantern": "node scripts/render-redlantern-doc.mjs",
    "bridge:obsidian": "node scripts/sync-obsidian.mjs",
    "boot:pack": "node scripts/build-boot-pack.mjs",
    "bridge:test": "node --test tests/*.test.mjs",
    "check": "npm run bridge:test && npm run backlog:validate && npm run content:validate && npm run bridge:doctor"
  },
  "engines": {
    "node": ">=20"
  }
}
