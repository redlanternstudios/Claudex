{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redlantern.studio/schemas/backlog.schema.json",
  "title": "Claudex Backlog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated_at", "active_objectives", "sources", "tasks"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "updated_at": { "type": "string", "format": "date-time" },
    "active_objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "updated_at"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "updated_at": { "type": "string", "format": "date-time" },
          "stale_after_days": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "previous_heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "KP": { "type": "array", "items": { "type": "string" } },
        "Rory": { "type": "array", "items": { "type": "string" } }
      }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "ownerAction": {
      "type": "object",
      "additionalProperties": true,
      "required": ["next_action", "definition_of_done"],
      "properties": {
        "title": { "type": "string" },
        "next_action": { "type": "string", "minLength": 1 },
        "definition_of_done": { "type": "string", "minLength": 1 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "owner", "project", "objective", "status", "updated_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "owner": { "enum": ["KP", "Rory", "joint", "unassigned"] },
        "project": { "type": "string", "minLength": 1 },
        "objective": { "type": "string" },
        "outcome": { "type": "string" },
        "next_action": { "type": "string" },
        "definition_of_done": { "type": "string" },
        "status": { "enum": ["ready", "in_progress", "blocked", "done", "parked", "cancelled"] },
        "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
        "effort": { "type": "integer", "minimum": 1, "maximum": 5 },
        "urgency": { "type": "integer", "minimum": 1, "maximum": 5 },
        "leverage": { "type": "integer", "minimum": 1, "maximum": 5 },
        "unblock": { "type": "integer", "minimum": 1, "maximum": 5 },
        "evidence_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "updated_at": { "type": "string", "format": "date-time" },
        "blocked": { "type": "boolean" },
        "blocker": { "type": "string" },
        "duplicate_of": { "type": "string" },
        "noise_reason": { "type": "string" },
        "completion_evidence": { "type": "string" },
        "manual_priority": { "type": "number", "minimum": 0, "maximum": 100 },
        "override_reason": { "type": "string" },
        "override_expires": { "type": "string" },
        "owner_actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "KP": { "$ref": "#/$defs/ownerAction" },
            "Rory": { "$ref": "#/$defs/ownerAction" }
          }
        }
      }
    }
  }
}
